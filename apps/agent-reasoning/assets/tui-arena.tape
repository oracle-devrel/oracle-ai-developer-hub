Output assets/tui-arena.gif
Set Shell bash
Set FontSize 13
Set Width 1400
Set Height 800
Set Theme "Catppuccin Mocha"
Set Padding 10

Type "cd /home/ubuntu/git/personal/agent-reasoning/tui && ./agent-tui"
Enter
Sleep 4s

# Navigate to Arena Mode
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
Type "j"
Sleep 200ms
# Select Arena Mode
Enter
Sleep 500ms

# Type arena query
Type "Explain recursion briefly"
Sleep 300ms
Enter

# Watch all agents race
Sleep 15s

Sleep 2s
