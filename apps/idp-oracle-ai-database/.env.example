# Oracle AI Database (Autonomous) — get these from the OCI console
# Connect string is the mTLS form from "Database connection" page (the _high service)
ORACLE_CONNECT_STRING=
ORACLE_USER=idp
ORACLE_PASSWORD=

# Path to the unzipped wallet directory (contains cwallet.sso, tnsnames.ora, etc.)
# Required for mTLS connections (i.e. when DB was created with "access from everywhere").
ORACLE_WALLET_LOCATION=

# Wallet password — the one you set in the OCI "Download wallet" dialog.
# Required by node-oracledb thin mode to decrypt ewallet.pem.
ORACLE_WALLET_PASSWORD=

# ADMIN password — used by `pnpm db:setup` to create the idp application user,
# and by `pnpm db:setup-oci-credential` to grant CREATE CREDENTIAL + open the
# outbound network ACL to OCI Generative AI.
ORACLE_ADMIN_PASSWORD=

# OCI Generative AI — classify + extract run inside the database via
# DBMS_VECTOR_CHAIN.UTL_TO_GENERATE_TEXT, which calls out to OCI Gen AI
# using the OCI_CRED credential registered by `pnpm db:setup-oci-credential`.
# To get these values: OCI console → My profile → Tokens and keys → Add API key.
OCI_USER_OCID=
OCI_TENANCY_OCID=
OCI_COMPARTMENT_OCID=
OCI_FINGERPRINT=
OCI_PRIVATE_KEY_PATH=
OCI_GENAI_REGION=eu-frankfurt-1

# OCI_GENAI_MODEL — chat model used by extraction (UTL_TO_GENERATE_TEXT, Chat endpoint).
# Must be a current, non-retired model. Available in eu-frankfurt-1 (verify in the OCI
# console under Analytics & AI → Generative AI → Playground for your region):
#   meta.llama-3.3-70b-instruct       Default. The model Oracle's own docs use. Good price + JSON.
#   cohere.command-a-03-2025          Cohere Command A — successor to the retired Command R+. Strong JSON.
#   meta.llama-4-maverick-17b-128e-instruct-fp8  Newer Llama 4 option.
# NOTE: cohere.command-r-plus-08-2024 / cohere.command-r-08-2024 are DEPRECATED and retire
# 2026-07-10 on on-demand — do not use them.
OCI_GENAI_MODEL=meta.llama-3.3-70b-instruct

# ONNX embedding model file in DATA_PUMP_DIR (uploaded by `pnpm db:onnx`).
ONNX_MODEL_FILE=all_MiniLM_L12_v2.onnx

# Used by scripts/seed.ts and the frontend at build time.
# Local dev: http://localhost:8787 ; Deployed: the CDK ApiUrl output.
API_BASE_URL=http://localhost:8787
VITE_API_BASE_URL=http://localhost:8787
