# Oracle Database 26ai connection
ORACLE_USER=ADMIN
ORACLE_PASSWORD=changeme
ORACLE_CONNECT_STRING=mydb_high

# OCI Generative AI
OCI_GENAI_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxxxxxxxxxx

# Optional model overrides. OCI rotates model IDs over time; if the defaults baked
# into llm.ts stop working, find the current ones in the Console at:
#   Analytics & AI → Generative AI → Pretrained Foundational Models
# OCI_CHAT_MODEL_ID=cohere.command-r-plus-08-2024
# OCI_EMBED_MODEL_ID=cohere.embed-english-v3.0

# Server
PORT=3001

# Demo user (when running the UI single-user)
DEMO_USER_ID=allen
