{
  "name": "oracle-agent-memory",
  "version": "0.1.0",
  "description": "Three-layer agent memory in Oracle AI Database 26ai. Demo: an AI that learns your social media voice over time.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "dev": "concurrently -k -n server,client \"npm run dev:server\" \"npm run dev:client\"",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/index.js",
    "schema": "tsx scripts/apply-schema.ts",
    "seed": "tsx scripts/seed-from-linkedin.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "oci-common": "^2.105.0",
    "oci-generativeaiinference": "^2.105.0",
    "oracledb": "^6.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/oracledb": "^6.5.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=20"
  }
}
