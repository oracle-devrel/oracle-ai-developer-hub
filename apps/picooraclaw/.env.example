# ── LLM Provider ──────────────────────────
# Uncomment and set the API key for your provider
# OPENROUTER_API_KEY=sk-or-v1-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx

# ── Chat Channel ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx
# LINE_CHANNEL_SECRET=xxx
# LINE_CHANNEL_ACCESS_TOKEN=xxx

# ── Web Search (optional) ────────────────
# BRAVE_SEARCH_API_KEY=BSA...

# ── Oracle Database 23ai ─────────────────
# PICO_ORACLE_ENABLED=true
# PICO_ORACLE_MODE=freepdb
# PICO_ORACLE_HOST=localhost
# PICO_ORACLE_PORT=1521
# PICO_ORACLE_SERVICE=FREEPDB1
# PICO_ORACLE_USER=picooraclaw
# PICO_ORACLE_PASSWORD=your_password_here
# PICO_ORACLE_ONNX_MODEL=ALL_MINILM_L12_V2
# PICO_ORACLE_AGENT_ID=default
# For ADB (Autonomous Database):
# PICO_ORACLE_MODE=adb
# PICO_ORACLE_DSN=your_adb_connection_string
# PICO_ORACLE_WALLET_PATH=/path/to/wallet

# ── Timezone ──────────────────────────────
TZ=Asia/Tokyo
