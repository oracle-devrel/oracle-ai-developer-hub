# Copy to oracle/.env (which is gitignored) and fill in. The CHANGE_ME_* passwords below work for
# the LOCAL sandbox container so the quickstart runs — but they're PLACEHOLDERS: set your own
# before anything real. NEVER commit oracle/.env. See SECURITY.md.

# --- LLM (only for the agent / wiki / memory / classifiers; search + MCP need NO key) ---
# Pick a provider — no code edits needed for the wiki/memory/classifier/idea steps:
LLM_PROVIDER=anthropic            # anthropic (default) | openai | ollama
# ANTHROPIC_API_KEY=sk-ant-...    # if anthropic (also powers the research agent's tool loop)
# OPENAI_API_KEY=sk-...           # if openai (pip install openai)
# OPENAI_BASE_URL=<endpoint>      # any OpenAI-compatible host works — e.g. Hugging Face
#                                 #   Inference (https://router.huggingface.co/v1 + hf_ token)
# OLLAMA_HOST=http://localhost:11434   # if ollama — RECOMMENDED free/local path:
#                                 #   brew install ollama && ollama pull llama3.2
#                                 #   then LLM_PROVIDER=ollama LLM_MODEL=llama3.2
# LLM_MODEL=<override>            # optional; defaults: anthropic=claude-opus-4-8,
#                                 #   openai=gpt-5.2, ollama=llama3.2 (pull it first)
# NOTE: the research agent's TOOL LOOP (server-side web search) is Anthropic-shaped —
# run it with Claude, or via an Anthropic-compatible gateway.

# --- MEMORY BACKEND (leave unset for the recommended default) ---
# unset (default)                 # Oracle's official AI Agent Memory package
#                                 #   (oracleagentmemory): maintained, benchmarked, automatic
#                                 #   extraction + hybrid retrieval — the honest recommendation.
#                                 #   EXCEPTION: with LLM_PROVIDER=ollama the resolver picks
#                                 #   the hand-built track for you (small local models fail
#                                 #   the package's extraction format, silently).
# MEMORY_BACKEND=custom           # the learning track / fully-local path: conversational +
#                                 #   semantic memory as hand-built tables you can read with
#                                 #   SQL (how the Oracle x DeepLearning.AI course teaches it)
# MEMORY_BACKEND=oamp             # force the package (overrides the ollama guard)
# OAMP_LLM_MODEL=<litellm id>     # oamp extraction model override (default per provider;
#                                 #   anthropic default: anthropic/claude-sonnet-5)
# BRAIN_USER=me                   # OAMP user scope for a single-user brain

# --- LOCAL Oracle container (the quickstart) ---
ORACLE_PWD=CHANGE_ME_SysPwd1          # SYSTEM/SYS password (placeholder — local sandbox only)
APP_PWD=CHANGE_ME_AppPwd1              # CCC app-schema password (placeholder — local sandbox only)
DB_USER=CCC
DB_DSN=localhost:1521/FREEPDB1

# --- CLOUD: Oracle Autonomous DB (optional; see docs/CLOUD_MIGRATION.md) ---
# DB_USER=CCC
# DB_DSN=<tns alias, e.g. mybrain_high>
# APP_PWD=<cloud app-user password>
# DB_WALLET_DIR=/abs/path/to/unzipped/wallet
# DB_WALLET_PASSWORD=<wallet password>

# --- Sources (optional) ---
# NOTION_TOKEN=ntn_...
# NOTION_DEAL_PROPS=Payment Status,Rate,Fee,Deliverables,Contract   # YOUR deal-tracker's column names — pages matching >=2 are skipped as private business data
# NOTION_DEAL_DATES=Published Date,Deadline                         # date columns to try for a deal's publish date
# NOTION_SERIES_CHECKBOX=My Show                                    # a boolean Notion column; checked pages get series='my_show'
# IG_ACCESS_TOKEN=<long-lived Instagram token; scripts/instagram_token.py>   # keep secret
# IG_APP_SECRET=<Meta app secret; only needed to mint/refresh the token>
# BRAIN_INCLUDE_BUSINESS=1   # load private brand-deal financials into a LOCAL vault only (never cloud)

# --- Hosted MCP (optional; set these as your HOST'S SECRETS, not here — see docs/HOSTED_MCP.md) ---
# MCP_AUTH_TOKEN=<random; bearer fallback used only when AUTHKIT_DOMAIN is unset>
# AUTHKIT_DOMAIN=https://<slug>.authkit.app     # turns on WorkOS OAuth (for claude.ai/ChatGPT)
# MCP_BASE_URL=https://<your-app>.fly.dev
# ALLOWED_EMAILS=you@example.com                # ONLY these emails are authorized (fail-closed)
# ALLOWED_SUBS=user_...                         # WorkOS user id(s); AuthKit tokens carry sub, not email
# MCP_READONLY=1                                # drop the write tool — server can only READ the brain
# DB_POOL_MAX=4                                 # max pooled DB sessions per process (DB_POOL=0 disables)

# Retrieval tuning: AI-chat items carry dense summaries that can outrank the published
# content they summarize. <1 makes published work win close calls (chats still surface
# when they're truly the best match). 1.0 disables the weighting.
# CHAT_SOURCE_WEIGHT=0.75

# Obsidian (or any markdown folder): absolute path; the daily sync ingests it
# OBSIDIAN_VAULT=/Users/you/Documents/MyVault

# --- Chat exports + research options ---
# EXPORT_WATCH_DIR=~/Downloads      # folder watched for ChatGPT/Claude export zips (default: ~/Downloads)
# RESEARCH_VERIFY=0                 # 1 (default) = fact-check research answers against run evidence

# --- Loop engineering (observability — see README's "Loop engineering" section) ---
# LOOP_LEDGER=<path>                # where LLM calls record tokens (default: exports/loop_ledger.jsonl)
# LOOP_LABEL=<name>                 # tags ledger lines with which loop spent them (sync sets it per step)
# EXPORT_SOURCES=chatgpt,claude,linkedin   # source_status panel: sources that only grow via YOUR exports
# EXPORT_DUE_DAYS=30                # panel flags an export-source as EXPORT DUE past this age
