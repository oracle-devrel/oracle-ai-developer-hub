# Copy to `.env` and fill in. The skill generates ORACLE_PWD for you.
# Never commit .env — it's in .gitignore.

# ─── Compose-level (oracle-aidb-docker-setup writes these) ──────────────────
COMPOSE_PROJECT_NAME=replace_me            # e.g. pdf-chat (isolates parallel runs)
ORACLE_PWD=replace_me_with_a_strong_pwd    # ≥12 chars, mixed case + digit, no $/@/"
ORACLE_PORT=1521                            # change for parallel runs (e.g. 1531, 1541)
ORACLE_EM_PORT=5500
ORACLE_VOLUME=oracle_<compose_project>_data

# ─── SYS / SYSTEM (only for app-user creation + SYSDBA-only operations) ─────
SYS_USER=SYSTEM
SYS_PASSWORD=                              # same value as ORACLE_PWD

# ─── Application user (every other skill uses these) ────────────────────────
# Created by oracle-aidb-docker-setup Step 6 with DEFAULT TABLESPACE USERS,
# CREATE MINING MODEL, EXECUTE ON SYS.DBMS_VECTOR. Connecting as SYSTEM
# fails ORA-43853 on JSON metadata columns — friction P0-3.
DB_USER=replace_me                         # e.g. PDF_CHAT
DB_PASSWORD=                               # generated by the skill
DB_DSN=localhost:1521/FREEPDB1

# ─── OCI Generative AI (all tiers — bearer-token API key, no OCI tenancy needed) ─
# Get an API key from the OCI Generative AI service console; the bearer-token
# path means you do NOT need ~/.oci/config, a compartment OCID, or any of the
# SigV1 ceremony. NEVER commit OCI_GENAI_API_KEY — .env is gitignored.
OCI_GENAI_API_KEY=replace_me_sk_value_from_oci_genai_console
OCI_GENAI_BASE_URL=https://inference.generativeai.us-phoenix-1.oci.oraclecloud.com
OCI_LLM_MODEL=xai.grok-4                   # full id required (NOT just `grok-4`)

# ─── Embeddings ─────────────────────────────────────────────────────────────
# Beginner (Python-side, MiniLM 384-dim).
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Intermediate / advanced (in-DB ONNX — same model, registered via onnx2oracle).
ONNX_MODEL_NAME=MY_MINILM_V1
# Optional: HuggingFace token to avoid unauthenticated rate limits when the
# beginner tier downloads MiniLM weights for the first time on a busy CDN.
# Generate at https://huggingface.co/settings/tokens — read-only is enough.
# (v3 friction P2-V3-3.) If unset, the download is anonymous and may stall.
# HF_TOKEN=hf_...

# ─── FastAPI adapter (every tier) ───────────────────────────────────────────
# Hard-coding 8000 collides when running multiple tier scaffolds on the same
# host. Pick a unique port per project (suggested: beginner=8000, intermediate
# =8010, advanced=8020). v3 friction P1-V3-2.
ADAPTER_PORT=8000
# Grok-4 latency is ~18s/call; multi-call agents need ~60s+ end-to-end. Set the
# adapter and any HTTP client to ≥300s to avoid silent empty-response timeouts.
# v3 friction P2-V3-N6.
ADAPTER_TIMEOUT=300

# ─── MCP / local tools ──────────────────────────────────────────────────────
ORACLE_MCP_SQL_MODE=read_only              # or read_write (with explicit confirmation)
ORACLE_MCP_ALLOWED_TOOLS=list_tables,describe_table,run_sql,vector_search

# ─── Archived: Ollama (no longer the default at any tier) ───────────────────
# Pre-restructure beginner used Ollama. The active tiers are OCI-only on
# purpose. If you want the Ollama-flavored ideas, see archive/.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_CHAT_MODEL=llama3.1:8b
