[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.build_meta"

[project]
name = "{{project_slug}}"
version = "0.1.0"
description = "{{one_line_pitch}}"
readme = "README.md"
requires-python = ">=3.11"
license = { text = "MIT" }
authors = [
    { name = "{{author}}" },
]
# The skill uncomments exactly one inference block during scaffolding.
# Leaving them all uncommented is wrong — pick the user's chosen backend.
dependencies = [
    "oracledb>=2.4",
    "langchain-oracledb>=0.1",
    "langchain>=0.3",
    "langchain-core>=0.3",
    "python-dotenv>=1.0",
    "pydantic>=2",

    # OAMP — conversational + per-user durable memory.
    # Used by advanced tier ideas 1 (hybrid analyst) and 2 (self-improving
    # research agent). Idea 3 (schema designer) does NOT need it; beginner
    # and intermediate tiers do NOT need it (single-user, OracleChatHistory
    # is enough). The skill comments this line back out for those tiers.
    # See shared/references/oamp.md.
    "oracleagentmemory>=26.4",

    # ── Inference: Ollama (beginner default, intermediate fallback) ──
    # "langchain-ollama>=0.2",

    # ── Inference: OCI Generative AI (intermediate / advanced) ──
    # "oci>=2.130",
    # "oci-openai>=0.1",   # see shared/references/oci-genai-openai.md — required for SigV1
    # "langchain-openai>=0.2",

    # ── Inference: BYO OpenAI-compatible URL ──
    # "langchain-openai>=0.2",

    # ── UI (intermediate + advanced only) ──
    # "gradio>=4.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0",
    "ruff>=0.5",
]

[project.scripts]
{{entrypoint_name}} = "{{package_name}}.main:main"

# `pip install -e .` requires this for src-layout projects.
[tool.setuptools.packages.find]
where = ["src"]

[tool.ruff]
line-length = 100
target-version = "py311"
